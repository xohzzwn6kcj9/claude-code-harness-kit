{
  "//": "Example wiring for ~/.claude/settings.json. Merge the blocks you want. Hook order within a matcher does not affect safety — an exit-2 block from ANY hook always wins, and a hook 'allow' never overrides a settings deny rule. The bash-guards are OPINIONATED (worktree workflow + personal bash style); include only the ones you want.",
  "permissions": {
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(npm publish:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/deny-secret-file-reads.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/bash-guards/git-branch-switch-guard.sh" },
          { "type": "command", "command": "~/.claude/hooks/bash-guards/xargs-procsub-guard.sh" },
          { "type": "command", "command": "~/.claude/hooks/bash-guards/brace-expansion-guard.sh" },
          { "type": "command", "command": "~/.claude/hooks/bash-guards/grep-tool-guard.sh" },
          { "type": "command", "command": "~/.claude/hooks/bash-guards/compound-cd-guard.sh" },
          { "type": "command", "command": "~/.claude/hooks/bash-guards/temp-dir-guard.sh" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/bash-guards/temp-dir-guard.sh" }
        ]
      },
      {
        "matcher": "mcp__.*playwright.*__browser_take_screenshot",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/playwright-screenshot-guard.sh" }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/auto-approve-readonly.sh" }
        ]
      }
    ]
  }
}
